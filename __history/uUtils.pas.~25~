unit uUtils;

interface

uses
  cxDBEdit,
  System.SysUtils,
  Vcl.StdCtrls,
  Vcl.Forms,
  Generics.Collections;

type
  Tutils = Class
    public
      class procedure DarSetFocus(AComponente: TcxDBTextEdit);
      class function ValidarDocumento(ADocumento: string): Boolean;
      class function IsCNPJValid(ACNPJ: string): Boolean;
      class function IsCPFValid(ACPF: string): Boolean;
      class function SomenteNumeros(const S: string): string;
      class function ValidarCxEdit(ACampo: TcxDBTextEdit; ALabel: TLabel): String;
      class procedure AbrirTela(AForm: TFormClass);
      class function ValidarCamposCadastros(AListaCampos: TDictionary<TCxDBTextEdit, TLabel>): String;
  end;

implementation

class procedure Tutils.AbrirTela(AForm: TFormClass);
begin
  var vForm := AForm.Create(nil);
  try
    vForm.ShowModal;
  finally
    vForm.Free;
  end;
end;

class procedure Tutils.DarSetFocus(AComponente: TWinControl);
  begin
    if (AComponente.CanFocus = false) then
    begin
      raise Exception.Create('O TcxDBTextEdit está marcado pra năo receber foco!' + Self.ClassName);
      Exit
    end;
  AComponente.SetFocus;
end;

  class function Tutils.SomenteNumeros(const S: string): string;
  var
    i: Integer;
  begin
    Result := '';
    for i := 1 to Length(S) do
      if S[i] in ['0'..'9'] then
        Result := Result + S[i];
  end;

class function Tutils.ValidarCamposCadastros(AListaCampos: TDictionary<TCxDBTextEdit, TLabel>): String;
begin
  var vcampo: TPair<TCxDBTextEdit, Tlabel>;
  var vRespostaValidacao: String;

  for vcampo in AListaCampos do
  begin
    vRespostaValidacao := TUtils.ValidarCxEdit(vcampo.key, vCampo.Value);
    if (vRespostaValidacao <> 'OK') then
    begin
      Result := vRespostaValidacao;
      TUtils.DarSetFocus(vcampo.Key);
      Exit;
    end
    else
    begin
      Result := 'OK';
    end;
  end;
end;

class function Tutils.ValidarCxEdit(ACampo: TcxDBTextEdit; ALabel: TLabel): String;
begin
  var vCaption: String := String(ALabel.Caption).TrimRight([':']);
  if (Trim(ACampo.Text) = '') then
  begin
    Result := 'O Campo ' + vCaption + ' năo pode estar em branco';
    Exit
  end
  else if (Length(ACampo.Text) < 2) then
  begin
    Result := 'O Campo ' + vCaption + ' precisa ter mais de 2 caracteres';
    Exit
  end
  else
  begin
    Result := 'OK';
  end;
end;

class function Tutils.ValidarDocumento(ADocumento: string): Boolean;
  var
    Limpo: string;
  begin
    Limpo := Tutils.SomenteNumeros(ADocumento);

    case Length(Limpo) of
      11: Result := IsCPFValid(Limpo);
      14: Result := IsCNPJValid(Limpo);
      else Result := False;
    end;
  end;

class function Tutils.IsCPFValid(ACPF: string): Boolean;
  var
    d1, d2: Array [1 .. 11] of Integer;
    s1, s2, i, resto: Integer;
    CPF_Limpo: string;
  begin
    Result := False;

    CPF_Limpo := '';
    for i := 1 to Length(ACPF) do
      if ACPF[i] in ['0' .. '9'] then
        CPF_Limpo := CPF_Limpo + ACPF[i];

    if (Length(CPF_Limpo) <> 11) or
       (CPF_Limpo = '00000000000') or (CPF_Limpo = '11111111111') or
       (CPF_Limpo = '22222222222') or (CPF_Limpo = '33333333333') or
       (CPF_Limpo = '44444444444') or (CPF_Limpo = '55555555555') or
       (CPF_Limpo = '66666666666') or (CPF_Limpo = '77777777777') or
       (CPF_Limpo = '88888888888') or (CPF_Limpo = '99999999999') then
      Exit;

    for i := 1 to 11 do
      d1[i] := StrToInt(CPF_Limpo[i]);


    s1 := 0;
    for i := 1 to 9 do
      s1 := s1 + (d1[i] * (11 - i));

    resto := s1 mod 11;
    if resto < 2 then
      s2 := 0
    else
      s2 := 11 - resto;

    if s2 <> d1[10] then
      Exit;

    s1 := 0;
    for i := 1 to 10 do
      s1 := s1 + (d1[i] * (12 - i));

    resto := s1 mod 11;
    if resto < 2 then
      s2 := 0
    else
      s2 := 11 - resto;

    if s2 <> d1[11] then
      Exit;

    Result := True;
  end;
class function Tutils.IsCNPJValid(ACNPJ: string): Boolean;
  var
    n: array[1..14] of Integer;
    i, soma, resto, d1, d2: Integer;
    CNPJ_Limpo: string;
  begin
    Result := False;
    CNPJ_Limpo := SomenteNumeros(ACNPJ);

    if Length(CNPJ_Limpo) <> 14 then Exit;

    if (CNPJ_Limpo = '00000000000000') or (CNPJ_Limpo = '11111111111111') then Exit;

    for i := 1 to 14 do
      n[i] := StrToInt(CNPJ_Limpo[i]);

    soma := n[1]*5 + n[2]*4 + n[3]*3 + n[4]*2 + n[5]*9 + n[6]*8 + n[7]*7 +
            n[8]*6 + n[9]*5 + n[10]*4 + n[11]*3 + n[12]*2;

    resto := soma mod 11;
    if resto < 2 then d1 := 0 else d1 := 11 - resto;
    if n[13] <> d1 then Exit;

    soma := n[1]*6 + n[2]*5 + n[3]*4 + n[4]*3 + n[5]*2 + n[6]*9 + n[7]*8 +
            n[8]*7 + n[9]*6 + n[10]*5 + n[11]*4 + n[12]*3 + n[13]*2;

    resto := soma mod 11;
    if resto < 2 then d2 := 0 else d2 := 11 - resto;
    if n[14] <> d2 then Exit;

    Result := True;
  end;




end.
