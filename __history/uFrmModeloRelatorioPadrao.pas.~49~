procedure TFrmModeloRelatorioPadrao.btnPesquisarClick(Sender: TObject);
begin
  Screen.Cursor := CrHourGlass;
  try
    btnPesquisar.SetFocus;
    if (FazerPesquisa = False) then
    begin
      ShowMessage('Nenhum informaçăo encontrada');
    end
  finally
    Screen.Cursor := crDefault;
  end;
end;

