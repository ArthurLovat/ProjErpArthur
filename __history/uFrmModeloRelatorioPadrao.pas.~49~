begin
  //A fazer
end;

function TFrmModeloRelatorioPadrao.MontarSqlILike(ACampo: array of String; AValor: String): String;
begin
  Result := '';
  for var vCampo: String in ACampo do
  begin
    Result := Result + ifthen(Result <> '', ' or ') + MontarSqlILike(vCampo, AValor);
  end;
  if (Result <> '') then
  begin
    Result := '(' + Result + ')';
  end;
end;

procedure TFrmModeloRelatorioPadrao.MostrarRelatorio;
begin
  if (GetDataSource.DataSet.IsEmpty) then
  begin
    Exit
  end;
  var vCaminhoRelatorio: String := IncludeTrailingPathDelimiter(extractFilePath(ParamStr(0))) + 'Relatorios';
  GetFrxReport.LoadFromFile(vCaminhoRelatorio + '\' + GetNomeArquivoFr3);
  GetFrxReport.ShowReport;
end;

function TFrmModeloRelatorioPadrao.MontarSqlILike(ACampo, AValor: String): String;
begin
  Result := ACampo + ' ILIKE all (select ''%'' || unnest(string_to_array(' + QuotedStr(AValor) + ', '' '')) || ''%'')';
end;

function TFrmModeloRelatorioPadrao.PegaCamposQueIraoProInsert: TList<TControl>;
begin
    var i: Integer;
    var j: Integer;
    var vGroupBox: TGroupBox;
    var vControl: TControl;
    var vContexto: TRttiContext;
    var vTipo: TRttiType;
    var vPropriedade: TRttiProperty;
    var vValor: TValue;

    Result := TList<TControl>.Create;
    vContexto := TRttiContext.Create;

    try
      for i := 0 to pnlFiltros.ControlCount -1 do //o .ControlCount ve qantos filhos tem dentro de pnlFiltros
      begin
        if (pnlFiltros.Controls[i] is TGroupBox) then
        begin
          vGroupBox := TGroupBox(pnlFiltros.Controls[i]);

          for j := 0 to vGroupBox.ControlCount - 1 do
          begin
            vControl := vGroupBox.Controls[j];
            vTipo := vContexto.GetType(vControl.ClassType);
            vPropriedade := vTipo.GetProperty('Text');

            if (Assigned(vPropriedade)) then
            begin
              if (vPropriedade.GetValue(vControl).ToString.Trim <> '') then
              begin
                Result.add(vControl);
              end;
            end;
        end;
      end;
    end;
    finally
      vContexto.Free;
    end;
end;

