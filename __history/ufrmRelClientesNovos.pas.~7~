unit ufrmRelClientesNovos;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, uFrmModeloRelatorioPadrao, cxGraphics,
  cxControls, cxLookAndFeels, cxLookAndFeelPainters, cxGeometry,
  dxFramedControl, cxContainer, cxEdit, cxStyles, cxCustomData, cxFilter,
  cxData, cxDataStorage, cxNavigator, dxDateRanges, dxScrollbarAnnotations,
  Data.DB, cxDBData, cxGridLevel, cxClasses, cxGridCustomView,
  cxGridCustomTableView, cxGridTableView, cxGridDBTableView, cxGrid,
  AdvGlowButton, cxGroupBox, dxGDIPlusClasses, Vcl.ExtCtrls, Vcl.StdCtrls,
  dxPanel, Vcl.DBCtrls, Vcl.ComCtrls, dxCore, cxDateUtils, cxSpinEdit,
  cxCheckBox, cxTextEdit, cxMaskEdit, cxDropDownEdit, cxCalendar, uDMMain;

type
  TfrmRelClientesNovos = class(TFrmModeloRelatorioPadrao)
    lblCidade: TLabel;
    lblEstado: TLabel;
    lblNome: TLabel;
    lblSituacao: TLabel;
    edtCidade: TEdit;
    edtNome: TEdit;
    cbxSituacao: TComboBox;
    lkUFF: TDBLookupComboBox;
    cxGroupBox1: TcxGroupBox;
    lblDataCadastro: TLabel;
    lblDataAlteracao: TLabel;
    lblCadAte: TLabel;
    lblAteAltera: TLabel;
    lblPorcentagem: TLabel;
    dtpCadastroDe: TcxDateEdit;
    dtpAlteracaoDe: TcxDateEdit;
    dtpCadastroAte: TcxDateEdit;
    dtpAlteracaoAte: TcxDateEdit;
    cbxCadastro: TcxCheckBox;
    cbxAlteracao: TcxCheckBox;
    spedtDias: TcxSpinEdit;
    dsListagem: TDataSource;
    dsListagemUf: TDataSource;
    grdListagemVwnome_fantasia: TcxGridDBColumn;
    grdListagemVwrazao_social: TcxGridDBColumn;
    grdListagemVwtelefone: TcxGridDBColumn;
    grdListagemVwdata_cadastro: TcxGridDBColumn;
    grdListagemVwdias_cadastro: TcxGridDBColumn;
    procedure FormCreate(Sender: TObject);
  private

  protected
    function FazerPesquisa: boolean; override;
    function GetDataSource: TDataSource; override;
    function GetNomeArquivoFr3: String; override;
    procedure VincularDadosRelatorio; override;

  public

  end;


implementation

{$R *.dfm}

function TfrmRelClientesNovos.FazerPesquisa: boolean;
begin
  DMMain.qryRelNovosClientes.Close;
  var vSql: String := 'SELECT cli.nome_fantasia, cli.razao_social, cli.telefone, cli.data_cadastro,' +
                      ' (CURRENT_DATE - CAST(cli.data_cadastro AS DATE)) AS dias_cadastro' +
                      ' FROM tclientes AS cli' +
                      ' INNER JOIN tbairros AS bairro ON cli.tbairros_id = bairro.id' +
                      ' INNER JOIN tcidades AS cid ON cli.tcidades_id = cid.id' +
                      ' INNER JOIN testados AS est ON cid.testados_id = est.id' +
                      ' WHERE 1=1';

  if (Trim(edtNome.Text) <> '') then
  begin
    vSql := vSql + ' AND ' + MontarSqlIlike(['cli.nome_fantasia', 'cli.razao_social'], edtNome.Text);
  end;
  if (Trim(edtCidade.Text) <> '') then
  begin
    vSql := vSql + ' AND ' + MontarSqlIlike('cid.nome_cidade', edtCidade.Text);
  end;
  if (Trim(lkUFF.Text) <> '') then
  begin
    vSql := vSql + ' AND ' + MontarSqlIlike('est.uf', lkUFF.Text);
  end;
  if (Trim(cbxSituacao.Text) <> 'Ambos') then
  begin
    if (Trim(cbxSituacao.Text) = 'Ativo') then
    begin
      vSql := vSql + ' and cli.ativo = true';
    end
    else
    begin
      vSql := vSql + ' and cli.ativo = false';
    end;
  end;
  if (cbxCadastro.Checked) then
  begin
    vSql := vSql + ' and cli.data_cadastro between ' + QuotedStr(FormatDateTime('yyyy-mm-dd', dtpCadastroDe.Date)) +
           ' and ' + QuotedStr(FormatDateTime('yyyy-mm-dd', dtpCadastroAte.Date));
  end;
  if (cbxAlteracao.Checked) then
  begin
    vSql := vSql + ' and cli.data_alteracao between ' + QuotedStr(FormatDateTime('yyyy-mm-dd', dtpAlteracaoDe.Date)) +
           ' and ' + QuotedStr(FormatDateTime('yyyy-mm-dd', dtpAlteracaoAte.Date));
  end;
  if (spedtDias.Value > 0) then
  begin
    vSql := vSql + ' and (CURRENT_DATE - CAST(cli.data_cadastro AS DATE)) >= :dias';
  end;

  vSql := vSql + ' ORDER BY cli.nome_fantasia';
  DMMain.qryRelNovosClientes.Sql.Text := vSql;

  if (spedtDias.Value > 0) then
  begin
    DMMAin.qryRelNovosClientes.ParamByName('dias').AsInteger := spedtDias.Value;
  end;

  DMMain.qryRelNovosClientes.Open;
  Result := not DMMain.qryRelNovosClientes.IsEmpty;
end;

procedure TfrmRelClientesNovos.FormCreate(Sender: TObject);
begin
  inherited;
  DMMain.FDQRelEstados.Open;
end;

function TfrmRelClientesNovos.GetDataSource: TDataSource;
begin
  Result := dsListagem;
end;

function TfrmRelClientesNovos.GetNomeArquivoFr3: String;
begin
  Result := 'RelClientesNovos.fr3';
end;

procedure TfrmRelClientesNovos.VincularDadosRelatorio;
begin
  Relatorios.frxDBDataSet.DataSource := GetDataSource;
end;

end.
