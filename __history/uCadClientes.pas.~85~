  cxEdit,
  Vcl.DBCtrls,
  cxMemo,
  cxDBEdit,
  Vcl.StdCtrls,
  cxTextEdit,
  cxButtons,
  Data.DB,
  uDMMain,
  Vcl.ExtCtrls,
  uUtils,
  uFrmModeloCadPadrao,
  Generics.Collections,
  uValidacao, cxMaskEdit, cxDropDownEdit, cxCalendar, dxBarBuiltInMenu,
  cxStyles, cxCustomData, cxFilter, cxData, cxDataStorage, cxNavigator,
  dxDateRanges, dxScrollbarAnnotations, cxDBData, cxGridLevel, cxClasses,
  cxGridCustomView, cxGridCustomTableView, cxGridTableView, cxGridDBTableView,
  cxGrid, dxGDIPlusClasses, cxPC, cxButtonEdit, ufrmCadClientesDependentes;

type
  TfrmCadClientes = class(TfrmModeloCadPadrao)
    dsListagemCidades: TDataSource;
    dsListagemBairros: TDataSource;
    cxPageControl1: TcxPageControl;
    tbsCliente: TcxTabSheet;
    DBCheckBox1: TDBCheckBox;
    lblRazaoSocial: TLabel;
    lblCpfCnpj: TLabel;
    lblNomeFantasia: TLabel;
    lblNumero: TLabel;
    lblEndereco: TLabel;
    lblComplemento: TLabel;
    lblPontoReferencia: TLabel;
    Label1: TLabel;
    Label2: TLabel;
    lblCidade: TLabel;
    lblBairros: TLabel;
    lblDtCad: TLabel;
    edtRazaoSocial: TcxDBTextEdit;
    edtCpfCnpj: TcxDBTextEdit;
    edtNomeFantasia: TcxDBTextEdit;
    edtRua: TcxDBTextEdit;
    lkCidade: TDBLookupComboBox;
    edtComplemento: TcxDBTextEdit;
    edtPontoReferencia: TcxDBTextEdit;
    edtCep: TcxDBTextEdit;
    edtNumero: TcxDBTextEdit;
    lkBairro: TDBLookupComboBox;
    pnlFoto: TPanel;
    dptDataCadastro: TcxDBDateEdit;
    tbsDependente: TcxTabSheet;
    lblComplementos: TLabel;
    imgComplementos: TImage;
    btnAdicionar: TcxButton;
    dsListagemClientesDependentes: TDataSource;
    grdListagem: TcxGrid;
    tbvListagem: TcxGridDBTableView;
