  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, uFrmModeloRelatorioPadrao, cxGraphics,
  cxControls, cxLookAndFeels, cxLookAndFeelPainters, cxGeometry,
  dxFramedControl, cxContainer, cxEdit, cxStyles, cxCustomData, cxFilter,
  cxData, cxDataStorage, cxNavigator, dxDateRanges, dxScrollbarAnnotations,
  Data.DB, cxDBData, cxGridLevel, cxClasses, cxGridCustomView,
  cxGridCustomTableView, cxGridTableView, cxGridDBTableView, cxGrid,
  AdvGlowButton, cxGroupBox, dxGDIPlusClasses, Vcl.ExtCtrls, Vcl.StdCtrls,
  dxPanel, Vcl.DBCtrls, Vcl.ComCtrls, dxCore, cxDateUtils, cxCheckBox,
  cxTextEdit, cxMaskEdit, cxDropDownEdit, cxCalendar, cxSpinEdit, uDMMain, uUtils;

type
  TFrmRelClientesDesatualizados = class(TFrmModeloRelatorioPadrao)
    lblCidade: TLabel;
    lblEstado: TLabel;
    lblNome: TLabel;
    lblSituacao: TLabel;
    edtCidade: TEdit;
    edtNome: TEdit;
    cbxSituacao: TComboBox;
    lkUFF: TDBLookupComboBox;
    cxGroupBox1: TcxGroupBox;
    lblDataCadastro: TLabel;
    lblDataAlteracao: TLabel;
    lblCadAte: TLabel;
    lblAteAltera: TLabel;
    dtpCadastroDe: TcxDateEdit;
    dtpAlteracaoDe: TcxDateEdit;
    dtpCadastroAte: TcxDateEdit;
    dtpAlteracaoAte: TcxDateEdit;
    cbxCadastro: TcxCheckBox;
    cbxAlteracao: TcxCheckBox;
    lblPorcentagem: TLabel;
    spedtDias: TcxSpinEdit;
    dsListagem: TDataSource;
    grdListagemVwnome_fantasia: TcxGridDBColumn;
    grdListagemVwrazao_social: TcxGridDBColumn;
    grdListagemVwdata_alteracao: TcxGridDBColumn;
    grdListagemVwdias_sem_atualizar: TcxGridDBColumn;
    grdListagemVwtelefone: TcxGridDBColumn;
    dsListagemUf: TDataSource;
