  dtpCadastroAte.Enabled := cbxCadastro.Checked;
end;

function TFrmRelatorioClientes.FazerPesquisa: Boolean;
begin
   DMMain.FDQRelClientes.Close;
  var qry: string;
  qry := 'SELECT cli.ativo ' +
         ', cli.nome_fantasia ' +
         ', cli.razao_social ' +
         ', cli.cpf_cnpj ' +
         ', cli.data_cadastro ' +
         ', cli.data_alteracao ' +
         ', cli.endereco ' +
         ', cli.numero_endereco ' +
         ', cli.complemento_endereco ' +
         ', bairro.nome_bairro ' +
         ', cid.nome_cidade ' +
         ', est.uf ' +
         'FROM tclientes as cli ' +
         'INNER JOIN tbairros as bairro ' +
         'on cli.tbairros_id = bairro.id ' +
         'INNER JOIN tcidades as cid ' +
         'on cli.tcidades_id = cid.id ' +
         'INNER JOIN testados as est ' +
         'on cid.testados_id = est.id ' +
         'WHERE 1=1';
  if (Trim(edtNome.Text) <> '') then
  begin
    qry := qry + ' AND ' + MontarSqlIlike(['cli.nome_fantasia', 'cli.razao_social'], edtNome.Text);
  end;

  if (Trim(edtCidade.Text) <> '') then
  begin
    qry := qry + ' AND ' + MontarSqlIlike('cid.nome_cidade', edtCidade.Text);
  end;

  if (Trim(lkUFF.Text) <> '') then
  begin
    qry := qry + ' AND ' + MontarSqlIlike('est.uf', lkUFF.Text);
  end;
  if (Trim(cbxSituacao.Text) <> 'Ambos') then
  begin
    if (Trim(cbxSituacao.Text) = 'Ativo') then
    begin
      qry := qry + ' and cli.ativo = true';
    end
    else
    begin
      qry := qry + ' and cli.ativo = false';
    end;
  end;

  if (cbxCadastro.Checked) then
  begin
    qry := qry + ' and cli.data_cadastro between ' +
          QuotedStr(FormatDateTime('yyyy-mm-dd', dtpCadastroDe.Date)) +
           ' and ' +
           QuotedStr(FormatDateTime('yyyy-mm-dd', dtpCadastroAte.Date));
  end;
  if (cbxAlteracao.Checked) then
  begin
    qry := qry + ' and cli.data_alteracao between ' +
           QuotedStr(FormatDateTime('yyyy-mm-dd', dtpAlteracaoDe.Date)) +
           ' and ' +
           QuotedStr(FormatDateTime('yyyy-mm-dd', dtpAlteracaoAte.Date));
  end;

  qry := qry + ' ORDER BY cli.nome_fantasia';

  DMMain.FDQRelClientes.SQL.Text := qry;
  DMMain.FDQRelClientes.Open;

  Result := not DMMAin.FDQRelClientes.IsEmpty;
end;

procedure TFrmRelatorioClientes.FormCreate(Sender: TObject);
begin
  inherited;
