    lblObservacao: TLabel;
    edtDescricao: TcxDBTextEdit;
    edtPrecoCusto: TcxDBTextEdit;
    edtCodigo: TcxDBTextEdit;
    edtPrecoVenda: TcxDBTextEdit;
    cxDBMmoObservacao: TcxDBMemo;
    dbLkCbbUnidadeMedida: TDBLookupComboBox;
    Label1: TLabel;
    Panel1: TPanel;
    cxTabSheet2: TcxTabSheet;
    lblComplementos: TLabel;
    imgComplementos: TImage;
    btnAdicionar: TcxButton;
