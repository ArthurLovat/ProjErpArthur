unit uListagemProdutos;

interface

uses
  Winapi.Windows,
  Winapi.Messages,
  System.SysUtils,
  System.Variants,
  System.Classes,
  Vcl.Graphics,
  Vcl.Controls,
  Vcl.Forms,
  Vcl.Dialogs,
  cxGraphics,
  cxControls,
  cxLookAndFeels,
  cxLookAndFeelPainters,
  cxStyles,
  cxCustomData,
  cxFilter,
  cxData,
  cxDataStorage,
  cxEdit,
  cxNavigator,
  dxDateRanges,
  dxScrollbarAnnotations,
  Data.DB,
  cxDBData,
  cxButtonEdit,
  Vcl.Menus,
  Vcl.StdCtrls,
  cxButtons,
  cxGridLevel,
  cxGridCustomTableView,
  cxGridTableView,
  cxGridDBTableView,
  cxClasses,
  cxGridCustomView,
  cxGrid,
  uDMMain,
  uCadProduto, cxContainer, cxTextEdit, cxMaskEdit, cxDropDownEdit,
  cxLookupEdit, cxDBLookupEdit, cxDBLookupComboBox;

type
  TfrmListagemProdutos = class(TForm)
    lblCadProdutos: TLabel;
    cxGrdProdutos: TcxGrid;
    cxGrdProdutosLevel1: TcxGridLevel;
    dsProdutos: TDataSource;
    cxGrdProdutosDBTableView1: TcxGridDBTableView;
    cxGrdProdutosDBTableView1ativo: TcxGridDBColumn;
    cxGrdProdutosDBTableView1descricao: TcxGridDBColumn;
    cxGrdProdutosDBTableView1codigo: TcxGridDBColumn;
    cxGrdProdutosDBTableView1data_cadastro: TcxGridDBColumn;
    cxGrdProdutosDBTableView1data_alteracao: TcxGridDBColumn;
    cxGrdProdutosDBTableView1preco_custo: TcxGridDBColumn;
    cxGrdProdutosDBTableView1preco_venda: TcxGridDBColumn;
    cxGrdProdutosDBTableView1observacao: TcxGridDBColumn;
    cxGrdProdutosDBTableView1tunidade_medida_id: TcxGridDBColumn;
    cxGrdProdutosDBTableViewbtnExcluir: TcxGridDBColumn;
    cxGrdProdutosDBTableViewEditar: TcxGridDBColumn;
    cxbtnNovo: TcxButton;
    cxBtnPesquisar: TcxButton;
    edtPesquisar: TEdit;
    procedure NovoOuEditar(AEditar: Boolean);
    procedure FormCreate(Sender: TObject);
    procedure cxbtnNovoClick(Sender: TObject);
    procedure cxGrdProdutosDBTableViewbtnExcluirPropertiesButtonClick(
      Sender: TObject; AButtonIndex: Integer);
    procedure cxGrdProdutosDBTableViewEditarPropertiesButtonClick(
      Sender: TObject; AButtonIndex: Integer);
    procedure AplicarFiltro;
    procedure cxBtnPesquisarClick(Sender: TObject);
    procedure edtPesquisarKeyDown(Sender: TObject; var Key: Word;
      Shift: TShiftState);
    procedure cxGrdProdutosDBTableView1CellDblClick(
      Sender: TcxCustomGridTableView;
      ACellViewInfo: TcxGridTableDataCellViewInfo; AButton: TMouseButton;
      AShift: TShiftState; var AHandled: Boolean);

  private
    { Private declarations }
  public
    { Public declarations }
  end;

implementation

{$R *.dfm}

{ TForm2 }

{ TfrmListagemProdutos }

procedure TfrmListagemProdutos.AplicarFiltro;
begin
  if(edtPesquisar.Text <> '') then
  begin
    DMMain.FDTProdutos.Filter := 'upper(descricao) like(''%' +
    UpperCase(StringReplace(edtPesquisar.Text, ' ', '%', [rfReplaceAll])) + '%'')';
  end;
  DMMain.FDTProdutos.Filtered := edtPesquisar.Text <> '';
end;

procedure TfrmListagemProdutos.cxbtnNovoClick(Sender: TObject);
begin
  NovoOuEditar(False);
end;

procedure TfrmListagemProdutos.cxBtnPesquisarClick(Sender: TObject);
begin
  AplicarFiltro;
end;

procedure TfrmListagemProdutos.cxGrdProdutosDBTableView1CellDblClick(
  Sender: TcxCustomGridTableView; ACellViewInfo: TcxGridTableDataCellViewInfo;
  AButton: TMouseButton; AShift: TShiftState; var AHandled: Boolean);
begin
  NovoOuEditar(true);
end;

procedure TfrmListagemProdutos.cxGrdProdutosDBTableViewbtnExcluirPropertiesButtonClick(
  Sender: TObject; AButtonIndex: Integer);
begin
  cxGrdProdutosDBTableView1.DataController.DeleteFocused;
end;

procedure TfrmListagemProdutos.cxGrdProdutosDBTableViewEditarPropertiesButtonClick(
  Sender: TObject; AButtonIndex: Integer);
begin
  NovoOuEditar(true);
end;

procedure TfrmListagemProdutos.edtPesquisarKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  if (key = vk_return) then
  begin
    cxBtnPesquisar.Click;
  end;

end;

procedure TfrmListagemProdutos.FormCreate(Sender: TObject);
begin
  DMMain.FDTProdutos.Open;
end;

procedure TfrmListagemProdutos.NovoOuEditar(AEditar: Boolean);
begin
  var vFrmCadProduto: TFrmCadProduto;
  vFrmCadProduto := TFrmCadProduto.Create(nil);
  try
    if (AEditar) then
    begin
      DMMain.FDTProdutos.Edit;
      DMMain.FDTProdutos.FieldByName('data_alteracao').AsDateTime := Now;
    end
    else
    begin
      DMMain.FDTProdutos.Append;
      DMMain.FDTProdutos.FieldByName('data_cadastro').AsDateTime := Now;
    end;

    if (vFrmCadProduto.ShowModal = mrOk ) then
    begin
      Application.MessageBox('Produto Cadastrado com sucesso!', 'Aviso:',
        MB_ICONQUESTION + MB_OK);
    end;
  finally
    vFrmCadProduto.Free;
  end;
end;

end.
