unit uListagemBairros;

interface

uses
  Winapi.Windows,
  Winapi.Messages,
  System.SysUtils,
  System.Variants,
  System.Classes,
  Vcl.Graphics,
  Vcl.Controls,
  Vcl.Forms,
  Vcl.Dialogs,
  cxGraphics,
  cxControls,
  cxLookAndFeels,
  cxLookAndFeelPainters,
  cxStyles,
  cxCustomData,
  cxFilter,
  cxData,
  cxDataStorage,
  cxEdit,
  cxNavigator,
  dxDateRanges,
  dxScrollbarAnnotations,
  Data.DB,
  cxDBData,
  cxButtonEdit,
  Vcl.Menus,
  Vcl.StdCtrls,
  cxButtons,
  cxGridLevel,
  cxGridCustomTableView,
  cxGridTableView,
  cxGridDBTableView,
  cxClasses,
  cxGridCustomView,
  cxGrid,
  uDMMain,
  uCadBairros;

type
  TfrmListagemBairros = class(TForm)
    lblBairros: TLabel;
    cxGrdBairros: TcxGrid;
    cxGrdBairrosVIew: TcxGridDBTableView;
    cxGrdProdutosDBTableViewbtnExcluir: TcxGridDBColumn;
    cxGrdProdutosDBTableViewEditar: TcxGridDBColumn;
    cxGrdBairrosLevel1: TcxGridLevel;
    cxbtnNovo: TcxButton;
    cxBtnPesquisar: TcxButton;
    edtPesquisar: TEdit;
    dsBairros: TDataSource;
    cxGrdBairrosVIewid: TcxGridDBColumn;
    cxGrdBairrosVIewnome_bairro: TcxGridDBColumn;
    procedure NovoOuEditar(AEditar: Boolean);
    procedure FormCreate(Sender: TObject);
    procedure AplicarFiltro;
    procedure edtPesquisarKeyDown(Sender: TObject; var Key: Word;
      Shift: TShiftState);
  private
    { Private declarations }
  public
    { Public declarations }
  end;


implementation

{$R *.dfm}


procedure TfrmListagemBairros.edtPesquisarKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  AplicarFiltro;
end;

procedure TfrmListagemBairros.FormCreate(Sender: TObject);
begin
  DMMain.FDTBairros.Open;
end;

procedure TfrmListagemBairros.AplicarFiltro;
begin
  if(edtPesquisar.Text <> '') then
  begin
    DMMain.FDTBairros.Filter := 'upper(nome_bairro) like(''%' +
    UpperCase(StringReplace(edtPesquisar.Text, ' ', '%', [rfReplaceAll])) + '%'')';
  end;
  DMMain.FDTBairros.Filtered := edtPesquisar.Text <> '';
end;

procedure TfrmListagemBairros.NovoOuEditar(AEditar: Boolean);
begin
  var vFrmCadBairros := TFrmCadBairros.Create(nil);
  try
    if (AEditar) then
    begin
      DMMain.FDTBairros.Edit;
    end
    else
    begin
      DMMain.FDTBairros.Append;
    end;

    if (vFrmCadBairros.ShowModal = mrOk ) then
    begin
      Application.MessageBox('Bairro Cadastrado com sucesso!', 'Aviso:', MB_ICONQUESTION + MB_OK);
    end;
  finally
    vFrmCadBairros.Free;
  end;
end;

end.
