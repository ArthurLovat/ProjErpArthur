unit uCadUnidadeMedida;

interface

uses
  Winapi.Windows,
  Winapi.Messages,
  System.SysUtils,
  System.Variants,
  System.Classes,
  Vcl.Graphics,
  Vcl.Controls,
  Vcl.Forms,
  Vcl.Dialogs,
  cxGraphics,
  cxControls,
  cxLookAndFeels,
  cxLookAndFeelPainters,
  cxContainer,
  cxEdit,
  cxTextEdit,
  Vcl.Menus,
  Vcl.StdCtrls,
  cxButtons,
  Data.DB,
  uDMMain,
  cxDBEdit,
  Vcl.DBCtrls,
  uUtils,
  uFrmModeloCadPadrao;

type
  TfrmCadUnidadesMedida = class(TfrmModeloCadPadrao)
    lblDescricao: TLabel;
    lblUnidade: TLabel;
    cxDBEdtDescricao: TcxDBTextEdit;
    cxDBEdtUnidadeMedida: TcxDBTextEdit;
    dbcbAtivo: TDBCheckBox;
    procedure cxbtnCadastrarClick(Sender: TObject);
    procedure cxbtnCancelarClick(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

implementation

{$R *.dfm}

procedure TfrmCadUnidadesMedida.cxbtnCadastrarClick(Sender: TObject);
begin
  var vCamposValidar: TDictionary<TCxDBTextEdit, TLabel> := TDictionary<TCxDBTextEdit, TLabel>.Create;
  try
    vCamposValidar.Add(edt, lblLogin);
    vCamposValidar.Add(edtsenha, lblSenha);
    vCamposValidar.Add(edtNome, lblNome);

    var vRespostaDeTodosOsCamposValidados: String := TUtils.ValidarCamposCadastros(vCamposValidar);

    if (vRespostaDeTodosOsCamposValidados <> 'OK') then
    begin
      Application.MessageBox(PWideChar(vRespostaDeTodosOsCamposValidados), 'Aviso:', MB_ICONQUESTION + MB_OK);
      Exit;
    end;

    GetDataSet.Post;
    ModalResult := mrOk;
  finally
    vCamposValidar.Free;
  end;



end;



end.
